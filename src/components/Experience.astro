---
import workData from './Data/Experience.json';

const categoryColors: Record<string, string> = {
    "Academic Publication": "#2E6F73",
    "Technical Illustration": "#C46A4A",
    "Patent Illustration": "#1E1D1A",
    "Children's Illustration": "#C46A4A",
};
---

<section class="pt-10 pb-20" id="experience">

    <!-- Section Header -->
    <div class="flex flex-col items-center text-center px-4 mx-auto max-w-screen-sm py-10 md:py-16">
        <h2 class="text-4xl font-normal md:text-5xl font-display" style="color: #1E1D1A;">
            My <span class="font-extrabold">Experience</span>
        </h2>
        <p class="mt-3 text-base font-body" style="color: #6F6A63; max-width: 480px;">
            A selection of projects I've delivered — from patents to publications.
        </p>
    </div>

    <!-- Featured List -->
    <div class="max-w-screen-lg mx-auto px-6 md:px-12 flex flex-col gap-0">
        {workData.map(({ category, client, title, description, link, linkLabel, period }, i) => (
            <div class="experience-row flex flex-col md:flex-row md:items-start gap-4 md:gap-12 py-8"
                 style={i < workData.length - 1 ? "border-bottom: 1px solid #DCD9D5;" : ""}>

                <!-- Left: period + category -->
                <div class="flex flex-col gap-2 md:w-48 flex-shrink-0">
                    <span class="text-xs font-body font-semibold uppercase tracking-widest"
                          style={`color: ${categoryColors[category] ?? '#2E6F73'};`}>
                        {category}
                    </span>
                    <span class="text-sm font-body" style="color: #6F6A63;">
                        {period}
                    </span>
                </div>

                <!-- Right: content -->
                <div class="flex flex-col gap-3 flex-1">
                    <div class="flex flex-col gap-1">
                        <p class="text-xs font-body uppercase tracking-wider" style="color: #6F6A63;">
                            {client}
                        </p>
                        <h3 class="text-base md:text-lg font-extrabold font-display" style="color: #1E1D1A;">
                            {title}
                        </h3>
                    </div>
                    <p class="text-sm md:text-base font-body leading-relaxed" style="color: #6F6A63; max-width: 640px;">
                        {description}
                    </p>
                    {link && (
                        <a href={link} target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-2 text-sm font-body font-semibold transition-all duration-200"
                           style="color: #2E6F73;"
                           onmouseover="this.style.gap='12px';"
                           onmouseout="this.style.gap='8px';">
                            {linkLabel}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M13 6l6 6-6 6"/>
                            </svg>
                        </a>
                    )}
                </div>

            </div>
        ))}
    </div>

</section>

<style>
    .experience-row + .experience-row {
        border-top: 1px solid #DCD9D5;
    }
</style>