---
// Hero.astro
---
<section class="relative flex flex-col-reverse items-center max-w-screen-xl px-4 mx-auto md:flex-row sm:px-6 p-8 md:py-[60px] md:px-20" id="hero">
    <div class="row items-center py-5 md:w-5/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <h2 class="text-4xl font-normal md:text-5xl font-display">
                Hello I'm <span class="font-bold" style="color: #2E6F73;">Precious</span>
            </h2>
            <h2 class="text-4xl font-bold md:text-5xl font-display">
                Technical Illustrator <span class="font-outline-sm">&amp; Visual Communicator</span>
            </h2>
            <h2 class="text-4xl font-bold md:text-5xl font-display">
                <span class="font-normal">Based In </span><span style="color: #C46A4A;">Barcelona</span>
            </h2>
            <p class="text-base font-normal leading-relaxed tracking-tight pb-8 font-body" style="color: #6F6A63; max-width: 480px;">
                I create precise, purposeful illustrations that make complex ideas instantly clear — from technical documentation and medical visuals to editorial and product design.
            </p>
        </div>

        <!-- Single CTA -->
        <div class="flex items-center gap-4">
            <a href="mailto:pregajii@gmail.com"
   class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-body font-medium text-white"
   style="background-color: #2E6F73; transition: background-color 300ms ease, transform 200ms ease;"
   onmouseover="this.style.backgroundColor='#245A5E'; this.style.transform='translateY(-2px)';"
   onmouseout="this.style.backgroundColor='#2E6F73'; this.style.transform='translateY(0)';">
    Let's Work Together
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</a>
        </div>

    </div>

    <div class="flex items-center py-5 md:w-7/12 md:pb-20 md:pt-10">
        <img src="/profile-picture.png" width="100%" alt="Precious Ajiboye — Technical Illustrator" loading="lazy"/>
    </div>
</section>