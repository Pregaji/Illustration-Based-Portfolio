---
// Hero.astro
---
<section class="relative flex flex-col-reverse items-center max-w-screen-xl px-4 mx-auto md:flex-row sm:px-6 p-8 md:py-[60px] md:px-20" id="hero">
    <div class="row items-center py-5 md:w-5/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <h2 class="text-4xl font-normal md:text-5xl" style="font-family: 'Instrument Serif', Georgia, serif;">
                Hello I'm <span class="font-bold" style="color: #2E6F73;">Precious</span>
            </h2>
            <h2 class="text-4xl font-bold md:text-5xl" style="font-family: 'Instrument Serif', Georgia, serif;">
                Technical Illustrator <span class="font-normal" style="-webkit-text-stroke: 1.5px #1E1D1A; color: transparent;">&amp; Visual Communicator</span>
            </h2>
            <h2 class="text-4xl font-bold md:text-5xl" style="font-family: 'Instrument Serif', Georgia, serif;">
                <span class="font-normal">Based In </span><span style="color: #C46A4A;">Barcelona</span>
            </h2>
            <p class="text-base font-normal leading-relaxed tracking-tight pb-8" style="color: #6F6A63; font-family: 'Inter', sans-serif; max-width: 480px;">
                I create precise, purposeful illustrations that make complex ideas instantly clear — from technical documentation and medical visuals to editorial and product design.
            </p>
        </div>

        <!-- Social / Contact Links -->
        <div class="flex items-center gap-4 flex-wrap">

            <!-- LinkedIn -->
            <a href="https://linkedin.com/in/precious-ajiboye" target="_blank" rel="noopener noreferrer"
               class="w-12 h-12 p-3 rounded flex items-center justify-center transition-all duration-200 hover:scale-105"
               style="background-color: #2E6F73;" aria-label="LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <rect x="2" y="9" width="4" height="12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="4" cy="4" r="2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>

            <!-- Email -->
            <a href="mailto:pregaji@gmail.com"
               class="w-12 h-12 p-3 rounded border-2 flex items-center justify-center transition-all duration-200 hover:scale-105"
               style="border-color: #1E1D1A;" aria-label="Email">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#1E1D1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="22,6 12,13 2,6" stroke="#1E1D1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>

            <!-- Behance -->
            <a href="#" target="_blank" rel="noopener noreferrer"
               class="w-12 h-12 p-3 rounded border-2 flex items-center justify-center transition-all duration-200 hover:scale-105"
               style="border-color: #1E1D1A;" aria-label="Behance">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029H23.726zm-7.726-3h3.427c-.103-1.2-.788-2-1.466-2-.951 0-1.813.694-1.961 2zM6.177 6.086C7.528 6.086 9 6.585 9 8.543c0 1.244-.63 1.989-1.65 2.403C8.764 11.3 9.5 12.175 9.5 13.543 9.5 15.9 7.757 17 5.7 17H1V6h5.177zm-.617 4c.776 0 1.44-.392 1.44-1.243 0-.851-.664-1.243-1.44-1.243H3v2.486h2.56zm.237 4.572c.924 0 1.703-.434 1.703-1.414 0-.98-.779-1.414-1.703-1.414H3v2.828h2.797z" fill="#1E1D1A"/>
                </svg>
            </a>

            <!-- Instagram -->
            <a href="#" target="_blank" rel="noopener noreferrer"
               class="w-12 h-12 p-3 rounded border-2 flex items-center justify-center transition-all duration-200 hover:scale-105"
               style="border-color: #1E1D1A;" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="#1E1D1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" stroke="#1E1D1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="#1E1D1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>

        </div>
        <!-- Social / Contact Links end -->
    </div>

    <div class="flex items-center py-5 md:w-7/12 md:pb-20 md:pt-10">
        <img src="/hero.svg" width="100%" alt="Precious Ajiboye — Technical Illustrator" loading="lazy"/>
    </div>
</section>

<!-- Google Fonts: Instrument Serif + Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300..700&display=swap" rel="stylesheet">