---
// Footer.astro
---

<footer style="background-color: #1E1D1A;">
    <div class="max-w-screen-xl mx-auto px-6 md:px-20 py-10">

        <!-- Top row -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 pb-8" style="border-bottom: 1px solid rgba(255,255,255,0.08);">

            

        </div>

        <!-- Bottom row -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-3 pt-6">
            <p class="text-xs font-body" style="color: rgba(255,255,255,0.3);">
                © <span id="currentYear"></span> Precious Ajiboye. All rights reserved.
            </p>
            <p class="text-xs font-body" style="color: rgba(255,255,255,0.3);">
                Designed & Built in Barcelona 🇪🇸
            </p>
        </div>

    </div>
</footer>

<script>
    document.getElementById("currentYear").innerHTML = `${new Date().getFullYear()}`;
</script>