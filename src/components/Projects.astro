---
import projectData from './Data/Projects.json';
---

<section class="pt-10 pb-20" id="projects">

    <!-- Section Header -->
    <div class="flex flex-col items-center text-center px-4 mx-auto max-w-screen-sm py-10 md:py-16">
        <h2 class="text-4xl font-normal md:text-5xl font-display" style="color: #1E1D1A;">
            My <span class="font-extrabold">Projects</span>
        </h2>
        <p class="mt-3 text-base font-body" style="color: #6F6A63; max-width: 480px;">
            A selection of illustration work — technical, editorial, and everything in between.
        </p>
    </div>

    <!-- Projects Grid -->
    <div class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projectData.map(({ id, category, name, description, link, linkLabel, image, placeholder }) => (
            <div class="flex flex-col rounded-2xl overflow-hidden transition-all duration-300"
                 style="background-color: #F9F8F5; box-shadow: 0 2px 12px rgba(30,29,26,0.06);"
                 onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 12px 32px rgba(30,29,26,0.12)';"
                 onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 12px rgba(30,29,26,0.06)';">

                <!-- Image / Placeholder -->
                <div class="relative w-full" style="aspect-ratio: 4/3; overflow: hidden;">
                    <img
                        src={image}
                        alt={name}
                        loading="lazy"
                        width="400"
                        height="300"
                        class="w-full h-full object-cover"
                        onerror="this.style.display='none'; document.getElementById('ph-' + this.dataset.id).style.display='flex';"
                        data-id={id}
                    />
                    <!-- Colour placeholder (shown if image fails) -->
                    <div id={`ph-${id}`}
                         class="absolute inset-0 items-center justify-center"
                         style={`background-color: ${placeholder}; display: none;`}>
                        <span class="text-6xl font-extrabold font-display text-white opacity-20">
                            {String(id).padStart(2, '0')}
                        </span>
                    </div>
                    <!-- Category badge -->
                    <span class="absolute top-4 left-4 text-xs font-body font-semibold px-3 py-1 rounded-full"
                          style="background-color: rgba(249,248,245,0.95); color: #1E1D1A;">
                        {category}
                    </span>
                </div>

                <!-- Content -->
                <div class="flex flex-col gap-3 p-6 flex-1">
                    <h3 class="text-base md:text-lg font-extrabold font-display leading-snug" style="color: #1E1D1A;">
                        {name}
                    </h3>
                    <p class="text-sm font-body leading-relaxed flex-1" style="color: #6F6A63;">
                        {description}
                    </p>
                    {link && (
                        <a href={link} target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-2 text-sm font-body font-semibold mt-2 transition-all duration-200"
                           style="color: #2E6F73;"
                           onmouseover="this.style.gap='12px';"
                           onmouseout="this.style.gap='8px';">
                            {linkLabel}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M13 6l6 6-6 6"/>
                            </svg>
                        </a>
                    )}
                </div>

            </div>
        ))}
    </div>

</section>